# ollama-rag-kit configuration. Every key shown below is optional except
# ATLAS_SECRET, which is required whenever the service is exposed through
# a Cloudflare Tunnel. Defaults match the values baked into app/config.py.

# --- Ollama ------------------------------------------------------------
OLLAMA_HOST=http://host.docker.internal:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=llama3.1:8b

# --- Chroma ------------------------------------------------------------
COLLECTION_NAME=atlas_docs

# --- Chunking / retrieval ---------------------------------------------
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=4

# --- Retrieval source ----------------------------------------------
# Document retrieval queries atlas-corpus over HTTP; this service no
# longer searches its own local collection. Defaults reach the corpus
# published on this host's port 8092 via the host gateway, the same
# route OLLAMA_HOST uses. See README: "Retrieval: atlas-corpus".
ATLAS_CORPUS_URL=http://host.docker.internal:8092
ATLAS_CORPUS_TIMEOUT_SECONDS=10
ATLAS_CORPUS_CONNECT_TIMEOUT_SECONDS=3

# --- Generation --------------------------------------------------------
NUM_CTX=8192
TEMPERATURE=0.2

# --- Conversation memory ----------------------------------------------
# Recent user/assistant turns are stored in their own Chroma collection,
# keyed by a client-generated UUID v4 forwarded by ramone-edge.
# MEMORY_CONTEXT_TURNS=0 disables memory reads and writes.
MEMORY_COLLECTION_NAME=ramone_sessions
MEMORY_MAX_TURNS=20
MEMORY_CONTEXT_TURNS=6
MEMORY_TTL_SECONDS=259200
MEMORY_MAX_MESSAGE_CHARS=4000

# --- Observability -----------------------------------------------------
LOG_LEVEL=INFO

# atlas-notify integration. Leave both blank to disable startup alerts.
NOTIFY_URL=https://api.atlas-systems.uk/notify
NOTIFY_TOKEN=
NOTIFY_ON_START=false

# --- Shared secret with ramone-edge -----------------------------------
# REQUIRED for any tunnel-exposed deployment. The app refuses to start
# without this. Generate one with:
#
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# Set the same value as wrangler secret UPSTREAM_SECRET in ramone-edge.
ATLAS_SECRET=
