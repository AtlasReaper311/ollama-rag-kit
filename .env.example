# Copy to .env (docker compose reads it automatically).
# Every value has a safe default; this file documents the knobs.

# Where Ollama listens, from the container's point of view. The default
# resolves on Docker Desktop (Windows/macOS) and on native Linux via the
# host-gateway alias in docker-compose.yml.
OLLAMA_HOST=http://host.docker.internal:11434

EMBED_MODEL=nomic-embed-text
LLM_MODEL=llama3.1:8b

COLLECTION_NAME=atlas_docs
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=4

# Ollama defaults to a 2048-token context window, which is too small once
# retrieved chunks are stuffed into the prompt. 4096 fits top_k=4 cleanly.
NUM_CTX=4096

# Optional: report lifecycle events (startup, ingest failures) to
# atlas-notify. Leave empty for a fully standalone kit.
NOTIFY_URL=
NOTIFY_TOKEN=
NOTIFY_ON_START=false

LOG_LEVEL=INFO
